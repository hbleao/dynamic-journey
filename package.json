{
  "name": "dynamic-journey",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:mem": "NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "next build",
    "build:mem": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:mem": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "changenotes": "node scripts/change-notes/generateChangeNotes.cjs",
    "changenotes:stdout": "node scripts/change-notes/generateChangeNotes.cjs --stdout",
    "changenotes:check": "node scripts/change-notes/verifyChangeNotes.cjs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.0.0",
    "lefthook": "^2.1.4",
    "sass": "^1.98.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
